  "keyFeatures": [
    "Electronic invoice generation (Facturas and Boletas)",
    "Credit and debit notes support",
    "XML UBL 2.1 generation and digital signing",
    "Direct SUNAT integration with automatic CDR retrieval",
    "Professional PDF generation with customizable templates",
    "Multi-company and multi-branch support",
    "OAuth2 authentication with Laravel Sanctum",
    "Greenter 5.1 integration for SUNAT compliance",
    "Automatic tax calculation (IGV, IVAP, ISC, ICBPER)",
    "Daily summary generation for boletas",
    "Document voiding and annulment",
    "Ubigeo (geographic codes) database",
    "Certificate management and validation",
    "Query service for electronic documents (CPE)"
  ],
  "publicApiSurface": [
    "POST /api/v1/invoices - Create invoice",
    "POST /api/v1/boletas - Create boleta",
    "POST /api/v1/invoices/{id}/send-sunat - Send invoice to SUNAT",
    "GET /api/v1/invoices/{id}/download-xml - Download XML",
    "GET /api/v1/invoices/{id}/download-cdr - Download CDR",
    "GET /api/v1/invoices/{id}/download-pdf - Download PDF",
    "POST /api/auth/login - Authenticate user",
    "GET /api/v1/companies - List companies",
    "POST /api/v1/companies - Create company",
    "GET /api/v1/branches - List branches",
    "POST /api/v1/clients - Create client",
    "POST /api/v1/consulta-cpe/factura/{id} - Query invoice status",
    "POST /api/v1/consulta-cpe/masivo - Bulk document query",
    "GET /api/v1/ubigeos/search - Search geographic codes",
    "GET /api/v1/correlatives/document-types - Get document types"
  ]
